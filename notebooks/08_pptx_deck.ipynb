   "source": [
    "# Notebook 08 — PowerPoint Consulting Deck\n",
    "## LA 2028 Olympic Games Strategic Playbook | SportsFanatics Consulting Agency\n",
    "\n",
    "**Milestone 9** — Builds a full professional consulting PowerPoint deck using `python-pptx`.\n",
    "\n",
    "**Steps:**\n",
    "1. Generate static PNG charts via Matplotlib (for embedding in slides)\n",
    "2. Assemble 20-slide consulting deck\n",
    "3. Save to `outputs/presentation/LA2028_Strategic_Playbook.pptx`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib\n",
    "matplotlib.use('Agg')\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "import matplotlib.gridspec as gridspec\n",
    "from matplotlib.patches import FancyBboxPatch\n",
    "from pathlib import Path\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "from pptx import Presentation\n",
    "from pptx.util import Inches, Pt, Emu\n",
    "from pptx.dml.color import RGBColor\n",
    "from pptx.enum.text import PP_ALIGN\n",
    "from pptx.util import Inches, Pt\n",
    "import io\n",
    "\n",
    "# ── Paths ──────────────────────────────────────────────────────────────────\n",
    "BASE       = Path('/Volumes/D Drive/Data analysis/Olympic data analysis')\n",
    "RAW        = BASE / 'data' / 'raw'\n",
    "PROCESSED  = BASE / 'data' / 'processed'\n",
    "TABLES     = BASE / 'outputs' / 'tables'\n",
    "FIGURES    = BASE / 'outputs' / 'figures'\n",
    "PRES       = BASE / 'outputs' / 'presentation'\n",
    "PRES.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# ── Color palette ──────────────────────────────────────────────────────────\n",
    "C_BLUE   = '#0085C7'\n",
    "C_YELLOW = '#F4C300'\n",
    "C_GREEN  = '#009F6B'\n",
    "C_RED    = '#DF0024'\n",
    "C_BLACK  = '#000000'\n",
    "C_BG     = '#F8F9FA'\n",
    "C_GREY   = '#6C757D'\n",
    "C_LGREY  = '#DEE2E6'\n",
    "\n",
    "CONT_COLORS = {\n",
    "    'Europe':   C_BLUE,\n",
    "    'Americas': C_RED,\n",
    "    'Asia':     C_YELLOW,\n",
    "    'Africa':   C_GREEN,\n",
    "    'Oceania':  C_BLACK,\n",
    "    'Other':    C_GREY,\n",
    "}\n",
    "\n",
    "def hex_to_rgb(h):\n",
    "    h = h.lstrip('#')\n",
    "    return RGBColor(int(h[0:2],16), int(h[2:4],16), int(h[4:6],16))\n",
    "\n",
    "plt.rcParams.update({\n",
    "    'font.family': 'Arial',\n",
    "    'font.size': 10,\n",
    "    'axes.spines.top': False,\n",
    "    'axes.spines.right': False,\n",
    "    'figure.dpi': 150,\n",
    "})\n",
    "\n",
    "print('Libraries loaded.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv(RAW / 'athlete_events.csv')\n",
    "noc = pd.read_csv(PROCESSED / 'noc_regions_clean.csv')\n",
    "lookup = noc[['NOC','region','continent']].drop_duplicates('NOC')\n",
    "\n",
    "summer = df[df['Season']=='Summer'].copy()\n",
    "summer = summer.merge(lookup, on='NOC', how='left')\n",
    "summer['continent'] = summer['continent'].fillna('Other')\n",
    "\n",
    "medals = summer.dropna(subset=['Medal']).copy()\n",
    "modern = summer[summer['Year'] >= 1984].copy()\n",
    "modern_medals = modern.dropna(subset=['Medal']).copy()\n",
    "\n",
    "forecast = pd.read_csv(PROCESSED / 'forecast_la2028_enriched.csv')\n",
    "alltime  = pd.read_csv(PROCESSED / 'noc_alltime_medal_table_enriched.csv')\n",
    "modern_tbl = pd.read_csv(PROCESSED / 'noc_modern_medal_table_enriched.csv')\n",
    "cont_summary = pd.read_csv(PROCESSED / 'continental_medal_summary.csv')\n",
    "cont_forecast = pd.read_csv(PROCESSED / 'continental_forecast_2028.csv')\n",
    "city_econ = pd.read_csv(TABLES / 'city_economic_benchmarks.csv')\n",
    "feat_imp  = pd.read_csv(TABLES / 'forecast_featureImportance.csv')\n",
    "validation = pd.read_csv(TABLES / 'forecast_validation_results.csv')\n",
    "\n",
    "print('Data loaded.')\n",
    "print(f'  athlete_events: {len(df):,} rows')\n",
    "print(f'  forecast: {len(forecast)} NOCs')\n",
    "print(f'  city_econ columns: {city_econ.columns.tolist()}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Generate Static PNG Charts"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Helper to save figure to bytes (for pptx) ─────────────────────────\n",
    "def fig_to_bytes(fig):\n",
    "    buf = io.BytesIO()\n",
    "    fig.savefig(buf, format='png', bbox_inches='tight', dpi=150)\n",
    "    buf.seek(0)\n",
    "    return buf\n",
    "\n",
    "chart_cache = {}  # dict: name -> BytesIO\n",
    "\n",
    "# ── CHART A: Gender participation trend ──────────────────────────────\n",
    "gender = (\n",
    "    summer[summer['Year'] >= 1948]\n",
    "    .groupby(['Year','Sex'])\n",
    "    .agg(athletes=('ID','nunique'))\n",
    "    .reset_index()\n",
    ")\n",
    "pivot_g = gender.pivot(index='Year', columns='Sex', values='athletes').fillna(0)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7,3.5))\n",
    "ax.fill_between(pivot_g.index, pivot_g.get('M',0), alpha=0.6, color=C_BLUE, label='Male')\n",
    "ax.fill_between(pivot_g.index, pivot_g.get('F',0), alpha=0.7, color=C_RED, label='Female')\n",
    "ax.set_title('Athlete Participation by Gender (1948–2016)', fontsize=12, fontweight='bold', pad=10)\n",
    "ax.set_xlabel('Olympic Year')\n",
    "ax.set_ylabel('Unique Athletes')\n",
    "ax.legend()\n",
    "ax.yaxis.set_major_formatter(plt.FuncFormatter(lambda x, _: f'{int(x):,}'))\n",
    "fig.tight_layout()\n",
    "chart_cache['gender'] = fig_to_bytes(fig)\n",
    "plt.close(fig)\n",
    "print('Chart A: gender trend saved')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CHART B: Top 10 all-time medal countries ──────────────────────────\n",
    "top10 = alltime.sort_values('Total', ascending=False).head(10)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 3.5))\n",
    "bars = ax.barh(top10['region'][::-1], top10['Total'][::-1], color=C_BLUE)\n",
    "for bar, gold in zip(bars, top10['Gold'][::-1]):\n",
    "    ax.text(bar.get_width() + 30, bar.get_y() + bar.get_height()/2,\n",
    "            f'{int(bar.get_width()):,}', va='center', fontsize=9)\n",
    "ax.set_title('Top 10 Nations — All-Time Olympic Medals', fontsize=12, fontweight='bold', pad=10)\n",
    "ax.set_xlabel('Total Medals')\n",
    "ax.xaxis.set_major_formatter(plt.FuncFormatter(lambda x, _: f'{int(x):,}'))\n",
    "fig.tight_layout()\n",
    "chart_cache['top10_alltime'] = fig_to_bytes(fig)\n",
    "plt.close(fig)\n",
    "print('Chart B: top 10 all-time saved')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CHART C: LA 2028 Top 15 forecast ──────────────────────────────────\n",
    "top15_fc = forecast.sort_values('Pred_2028_Ensemble', ascending=False).head(15).copy()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 4))\n",
    "colors = [C_RED if row['Is_Host'] == 1 else C_BLUE for _, row in top15_fc.iterrows()]\n",
    "bars = ax.barh(top15_fc['region'][::-1], top15_fc['Pred_2028_Ensemble'][::-1], color=colors[::-1])\n",
    "\n",
    "# Error bars\n",
    "xerr_low  = (top15_fc['Pred_2028_Ensemble'] - top15_fc['Pred_2028_Low']).values[::-1]\n",
    "xerr_high = (top15_fc['Pred_2028_High'] - top15_fc['Pred_2028_Ensemble']).values[::-1]\n",
    "for i, bar in enumerate(bars):\n",
    "    ax.errorbar(bar.get_width(), bar.get_y() + bar.get_height()/2,\n",
    "                xerr=[[xerr_low[i]], [xerr_high[i]]], fmt='none',\n",
    "                color='#555', capsize=3, lw=1.5)\n",
    "    ax.text(bar.get_width() + 5, bar.get_y() + bar.get_height()/2,\n",
    "            f'{bar.get_width():.0f}', va='center', fontsize=8)\n",
    "\n",
    "ax.set_title('LA 2028 Medal Forecast — Top 15 Nations', fontsize=12, fontweight='bold', pad=10)\n",
    "ax.set_xlabel('Predicted Medals')\n",
    "legend_patches = [mpatches.Patch(color=C_RED, label='USA (Host)'),\n",
    "                  mpatches.Patch(color=C_BLUE, label='Other Nations')]\n",
    "ax.legend(handles=legend_patches, loc='lower right', fontsize=8)\n",
    "fig.tight_layout()\n",
    "chart_cache['forecast_top15'] = fig_to_bytes(fig)\n",
    "plt.close(fig)\n",
    "print('Chart C: LA 2028 forecast top 15 saved')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
